# ============================================================================
#  Fancy RSVP — PRODUCTION environment (fancyrsvp.com)
#  Copy this file to `.env` on the production server and fill the SECRET values.
#  NEVER commit the filled-in file. Keep secrets out of git and ecosystem.config.js.
#
#  Legend:  <FILL>  = you must paste a real secret      (•) = pre-set, leave as-is
# ============================================================================

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
# Public browser origin(s). Comma-separated allowlist — doubles as CORS list AND
# the Stripe Checkout return-URL allowlist. Include BOTH apex and www so a user
# who started on either lands back on the SAME origin (a mismatch logs them out).
FRONTEND_URL=https://fancyrsvp.com,https://www.fancyrsvp.com
# Public base of the API (used to build QR / invitation links). Same domain, /api.
BACKEND_URL=https://fancyrsvp.com
# NOTE: `trust proxy` is set in code (app.js) — no env var needed. It makes the
# rate limiters and req.protocol work correctly behind nginx.

# ── Auth / security secrets (REQUIRED — app refuses to boot without these) ────
JWT_SECRET=<FILL: long random string, e.g. `openssl rand -hex 32`>
QR_JWT_SECRET=<FILL: a DIFFERENT long random string>
IP_HASH_SALT=<FILL: random 32-byte hex for analytics IP hashing>
GOOGLE_CLIENT_ID=<FILL: production Google OAuth client id>.apps.googleusercontent.com

# ── Supabase (PRODUCTION project — same DB the cutover SQL runs against) ──────
SUPABASE_URL=https://<FILL-prod-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<FILL: PRODUCTION service_role key — never expose to the browser>

# ── Feature flags: go-live switches ──────────────────────────────────────────
# Both must be `true` to actually charge cards / send real SMS. Stripe also
# requires STRIPE_SECRET_KEY to be present (belt-and-suspenders against half-config).
PAYMENTS_STRIPE_ENABLED=true
SMS_ENABLED=true

# ── Stripe (LIVE account — the new email/account, NOT the test account) ───────
# Required only because PAYMENTS_STRIPE_ENABLED=true above.
STRIPE_SECRET_KEY=<FILL: sk_live_... from the NEW Live account>
# The signing secret of the LIVE webhook endpoint you create at:
#   https://fancyrsvp.com/api/v1/payments/webhook   (events: checkout.session.completed,
#   charge.refunded, charge.dispute.created, charge.dispute.updated, charge.dispute.closed)
STRIPE_WEBHOOK_SECRET=<FILL: whsec_... from the LIVE endpoint (distinct from test)>

# ── Twilio (real SMS) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<FILL: live AC... SID>
TWILIO_AUTH_TOKEN=<FILL: live auth token>
# Your purchased, SMS-capable E.164 number — NOT the +15005550006 magic test number.
TWILIO_PHONE_NUMBER=<FILL: +1XXXXXXXXXX>
# Set EXPLICITLY. Behind nginx the auto-derived URL would be http:// and break
# Twilio signature verification → no delivery reconciliation / auto-refunds.
SMS_STATUS_CALLBACK_URL=https://fancyrsvp.com/api/v1/public/sms/status

# ── Brevo (transactional email: receipts, activation, invitations) ───────────
BREVO_API_KEY=<FILL: production Brevo API key>
BREVO_FROM_EMAIL=noreply@fancyrsvp.com
BREVO_FROM_NAME=Fancy RSVP
# Make sure the from-domain has SPF/DKIM authenticated so receipts don't spam-folder.

# ── Cloudflare Turnstile (CAPTCHA on public RSVP — recommended vs spam) ───────
# If left blank, the CAPTCHA check is disabled (RSVP still works).
TURNSTILE_SECRET=<FILL or leave blank to disable>

# ── Background workers (sensible defaults; shown for clarity) ─────────────────
# Large SMS campaigns are processed by an in-process worker. It is ON by default
# (leader = pm2 instance 0). Do NOT set this to false in production.
# SMS_WORKER_ENABLED=true
# Daily-revenue rollup for finance reporting — ON by default. Leave enabled.
# REVENUE_ROLLUP_ENABLED=true
# Automated "event details changed" guest emails — OFF by default. Opt-in only.
# EMAIL_AUTOMATION_ENABLED=false

# ── Optional infra ───────────────────────────────────────────────────────────
# Shared rate-limit store across pm2 cluster workers. Without it each worker keeps
# its own counters (effective limit ≈ N×). Set if you run Redis.
# REDIS_URL=redis://127.0.0.1:6379
# LOG_LEVEL=info
# DANGER: never set DISABLE_RATE_LIMIT in production. Load-testing only.
