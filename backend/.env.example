# App Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
JWT_SECRET=your-strong-jwt-secret-here
QR_JWT_SECRET=your-strong-qr-jwt-secret-here

# Supabase Configurations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-never-share

# Analytics
IP_HASH_SALT=your-random-32-byte-hex-string-for-ip-hashing

# ── Feature flags (paid integrations) ──────────────────────────────────────
# Both default to OFF. The platform runs fully on MANUAL payment with these off,
# and boots even with no Stripe/Twilio keys. Flip to true (with the keys below)
# to go live — no code changes needed.
#   PAYMENTS_STRIPE_ENABLED=true  → card checkout (event fee + SMS-credit top-ups)
#   SMS_ENABLED=true              → real Twilio SMS (otherwise logged in mock mode)
PAYMENTS_STRIPE_ENABLED=false
SMS_ENABLED=false

# Stripe Configurations (required only when PAYMENTS_STRIPE_ENABLED=true)
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio Configurations (used only when SMS_ENABLED=true)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890
# Public webhook URLs (needed for Twilio signature verification behind a proxy):
# delivery receipts + inbound STOP/HELP opt-out recording.
SMS_STATUS_CALLBACK_URL=https://yourdomain.com/api/v1/public/sms/status
SMS_INBOUND_WEBHOOK_URL=https://yourdomain.com/api/v1/public/sms/inbound

# Brevo (Email) Configurations
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=noreply@yourdomain.com
BREVO_FROM_NAME=Fancy RSVP

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
