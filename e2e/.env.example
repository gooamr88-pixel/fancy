# Copy to e2e/.env and fill in. NEVER point at production with real credentials.

# Frontend base URL under test (the running Next.js app).
BASE_URL=http://localhost:3000

# A test ORGANIZER account that already exists and is email-verified.
ORG_EMAIL=organizer@example.com
ORG_PASSWORD=Secret123!

# An ACTIVE (paid + admin-approved) event the test organizer OWNS, used for the
# guest-RSVP + live-dashboard-update steps. The built-in `demo` event is always
# live and is a safe default for the guest flow; for the live-update assertion the
# organizer must OWN this event (see README).
LIVE_SLUG=demo

# Optional: the eventId matching LIVE_SLUG, so the dashboard live-update step can
# deep-link straight to that event's RSVP list. Leave blank to let the test find it.
LIVE_EVENT_ID=
