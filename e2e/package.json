{
  "name": "fancy-rsvp-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright cross-browser / mobile E2E + smoke suite for Fancy RSVP",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:chrome": "playwright test --grep @smoke --project=\"Desktop Chrome\"",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.5"
  }
}
